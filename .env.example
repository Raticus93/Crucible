# ─── Crucible Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values you need.
# Only keys for the providers you actually use are required.

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-key-here

# ─── Mistral ──────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-key-here

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here

# ─── DeepSeek ─────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-key-here

# ─── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key-here

# ─── Together AI ──────────────────────────────────────────────────────────────
TOGETHER_API_KEY=your-together-key-here

# ─── DeepInfra ────────────────────────────────────────────────────────────────
DEEPINFRA_API_KEY=your-deepinfra-key-here

# ─── Google / Gemini ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-key-here

# ─── Crucible Service ─────────────────────────────────────────────────────────
# Path to your config file (defaults to crucible_config.json in project root)
CRUCIBLE_CONFIG_PATH=./crucible_config.json

# ChromaDB persistent store location
CHROMA_PERSIST_DIR=./chroma_db

# API server host/port
CRUCIBLE_HOST=0.0.0.0
CRUCIBLE_PORT=8420
